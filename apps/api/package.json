{
  "name": "@kraftbase/api", "version": "1.0.0", "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts", "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js", "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run", "db:generate": "prisma generate", "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy", "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@kraftbase/shared": "*", "@prisma/client": "^6.4.1", "@privy-io/node": "^0.26.0",
    "cors": "^2.8.5", "decimal.js": "^10.5.0", "dotenv": "^16.4.7", "express": "^4.21.2",
    "express-rate-limit": "^7.5.0", "helmet": "^8.0.0", "pino": "^9.6.0", "pino-http": "^10.4.0",
    "socket.io": "^4.8.1", "ws": "^8.18.0", "zod": "^3.24.2"
  },
  "devDependencies": { "@types/cors": "^2.8.17", "@types/express": "^5.0.0", "@types/node": "^22.13.4", "@types/ws": "^8.5.14", "prisma": "^6.4.1", "tsx": "^4.19.3", "typescript": "^5.7.3", "vitest": "^3.0.5" }
}
